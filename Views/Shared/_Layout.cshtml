<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ComicsBox</title>

    <!-- Favicon classique -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    <!-- Apple touch icon (pour iOS / iPadOS) -->
    <link rel="apple-touch-icon" sizes="180x180" href="~/logo192.png" />

    <!-- Manifest pour PWA -->
    <link rel="manifest" href="~/manifest.json" />

    <!-- Thème couleur (barre de navigation mobile) -->
    <meta name="theme-color" content="#ff6b35" />

    <!-- Styles CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body id="body" class="theme-dark d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-modern mb-3">
            <div class="container-fluid d-flex align-items-center justify-content-between">

                <!-- LEFT: Home + Back -->
                <div class="d-flex align-items-center">
                    <!-- Home -->
                    <button class="header-btn" type="button" onclick="home()" title="Accueil">
                        🏠
                    </button>

                    <!-- Back (n'affiche pas sur Home) -->
                    @if (ViewData["ShowBackButton"] as bool? ?? false)
                    {
                        <button class="header-btn" type="button" onclick="back()" title="Retour">
                            ◀️
                        </button>
                    }
                </div>

                <!-- RIGHT: Search + Theme -->
                <div class="d-flex align-items-center">
                    <!-- Search form -->
                    <form class="d-flex align-items-center search-form" method="get" action="@Url.Action("Search", "Comics")">
                        <input class="form-control" type="search" name="query" placeholder="Rechercher des séries..." aria-label="Search">
                        <button class="header-btn" type="submit">🔍</button>
                    </form>

                    <!-- Sort toggle -->
                    <button id="sort-toggle" class="header-btn" type="button">🆕</button>

                    <!-- Theme toggle -->
                    <button id="theme-toggle" class="header-btn" type="button">🌙</button>
                </div>

            </div>
        </nav>
    </header>

    <main role="main" class="flex-fill container pb-3">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- THEME TOGGLE -->
    <script>
        function home() {
            const pathBase = '@Context.Request.PathBase';
            if(pathBase === "") {
                window.location.href = `/`;
            }
            else {
                const newUrl = window.location.href.split(pathBase)[0] + pathBase + `/`;
                window.location.href = newUrl;
            }
        }

        function back() {
            window.history.back();
        }

        (function(){
            const body = document.getElementById('body');
            const sortToggle = document.getElementById('sort-toggle');
            const themeToggle = document.getElementById('theme-toggle');

            const sort = localStorage.getItem('cb-sort');
            if(sort) {
                sortToggle.textContent = sort === 'new' ? '🆕' : '🔤';
            } else {
                localStorage.setItem('cb-sort', 'alpha');
                sortToggle.textContent = '🔤';
            }

            sortToggle.addEventListener('click', () => {
                const currentSort = localStorage.getItem('cb-sort');
                const newSort = currentSort === 'new' ? 'alpha' : 'new';
                localStorage.setItem('cb-sort', newSort);
                sortToggle.textContent = newSort === 'new' ? '🆕' : '🔤';

                const url = new URL(window.location.href);
                url.searchParams.set('sort', newSort);
                window.location.replace(url.toString());
            });

            const theme = localStorage.getItem('cb-theme');
            if(theme) {
                body.className = theme + ' d-flex flex-column min-vh-100';
                themeToggle.textContent = theme === 'theme-dark' ? '☀️' : '🌙';
            }

            themeToggle.addEventListener('click', () => {
                if(body.classList.contains('theme-dark')){
                    body.classList.remove('theme-dark');
                    body.classList.add('theme-light');
                    localStorage.setItem('cb-theme','theme-light');
                    themeToggle.textContent = '🌙';
                } else {
                    body.classList.remove('theme-light');
                    body.classList.add('theme-dark');
                    localStorage.setItem('cb-theme','theme-dark');
                    themeToggle.textContent = '☀️';
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
